<%- include('./partials/header') %>

<div class="bg-gray-50 min-h-screen">
  <div
    class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8 text-gray-800"
  >
    <div class="mb-6 sm:mb-8">
      <h1 class="text-xl sm:text-2xl font-bold text-gray-900">About Scatch</h1>
      <p class="text-sm text-gray-600 mt-1">
        Building a trusted shopping experience inspired by global ecommerce
        standards.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
      <section
        class="lg:col-span-2 bg-white rounded-lg shadow-sm border border-gray-200"
      >
        <div class="border-b border-gray-200 px-4 sm:px-6 py-4">
          <h2 class="text-base sm:text-lg font-semibold text-gray-900">
            Who We Are
          </h2>
        </div>
        <div
          class="p-4 sm:p-6 space-y-5 text-sm sm:text-base text-gray-700 leading-relaxed"
        >
          <p>
            At <span class="text-yellow-500 font-semibold">Scatch</span>, we
            curate premium men's and women's clothing along with elegant,
            high-quality watches designed for modern lifestyles. Our collections
            are selected to balance style, comfort, and value.
          </p>
          <p>
            We focus on dependable quality, transparent pricing, and service
            that feels smooth from product discovery to post-order support.
          </p>
        </div>
      </section>

      <aside class="space-y-6">
        <section class="bg-white rounded-lg shadow-sm border border-gray-200">
          <div class="border-b border-gray-200 px-4 py-4">
            <h2 class="text-base font-semibold text-gray-900">Our Promise</h2>
          </div>
          <ul class="p-4 space-y-3 text-sm text-gray-700">
            <li class="border border-gray-200 rounded-lg px-3 py-2">
              Curated quality-first catalog
            </li>
            <li class="border border-gray-200 rounded-lg px-3 py-2">
              Secure checkout experience
            </li>
            <li class="border border-gray-200 rounded-lg px-3 py-2">
              Responsive support team
            </li>
            <li class="border border-gray-200 rounded-lg px-3 py-2">
              Customer-first policies
            </li>
          </ul>
        </section>
      </aside>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mt-6">
      <section class="bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="border-b border-gray-200 px-4 sm:px-6 py-4">
          <h2 class="text-base sm:text-lg font-semibold text-gray-900">
            Our Mission
          </h2>
        </div>
        <div
          class="p-4 sm:p-6 text-sm sm:text-base text-gray-700 leading-relaxed"
        >
          To make premium fashion and timepieces more accessible through a
          trusted digital shopping experience with consistent product quality,
          safe payments, and fast customer support.
        </div>
      </section>

      <section class="bg-white rounded-lg shadow-sm border border-gray-200">
        <div class="border-b border-gray-200 px-4 sm:px-6 py-4">
          <h2 class="text-base sm:text-lg font-semibold text-gray-900">
            Why Customers Choose Us
          </h2>
        </div>
        <ul
          class="p-4 sm:p-6 space-y-2 text-sm sm:text-base text-gray-700 list-disc pl-5"
        >
          <li>Wide selection across men, women, and accessories</li>
          <li>Reliable order processing and delivery updates</li>
          <li>Clear returns and support channels</li>
          <li>Designs that blend timeless and modern trends</li>
        </ul>
      </section>
    </div>

    <section class="bg-white rounded-lg shadow-sm border border-gray-200 mt-6">
      <div
        class="p-4 sm:p-6 flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4"
      >
        <div>
          <h2 class="text-base sm:text-lg font-semibold text-gray-900">
            Have questions about Scatch?
          </h2>
          <p class="text-sm text-gray-600 mt-1">
            Our team is ready to help with products, orders, and policy queries.
          </p>
        </div>
        <a
          href="/contact"
          class="inline-flex items-center justify-center bg-yellow-500 hover:bg-yellow-600 text-white px-5 py-2.5 rounded-lg text-sm font-medium transition"
        >
          Contact Us
        </a>
      </div>
    </section>
  </div>
</div>

<%- include('./partials/footer') %>
