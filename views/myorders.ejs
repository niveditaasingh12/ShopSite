<style>
  /* Custom styles for line clamping */
  .line-clamp-2 {
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  
  /* Remove underline from button links */
  .no-underline {
    text-decoration: none !important;
  }
  
  /* Loading spinner animation */
  @keyframes spin {
    from {
      transform: rotate(0deg);
    }
    to {
      transform: rotate(360deg);
    }
  }
  
  .animate-spin {
    animation: spin 1s linear infinite;
  }
  
  /* Flash message fade animation */
  @keyframes fadeInOut {
    0% {
      opacity: 1;
    }
    90% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }
</style>

<script>
  // Auto-dismiss flash messages
  <% if (success || error) { %>
  setTimeout(function() {
    const flashMessage = document.getElementById('flashMessage');
    if (flashMessage) {
      flashMessage.style.animation = 'fadeInOut 3s ease-in-out forwards';
      setTimeout(() => flashMessage.remove(), 3000);
    }
  }, 3000);
  <% } %>

  // Cancel Modal Management
  let currentCancelForm = null;

  function handleCancelOrder(event, form) {
    event.preventDefault();
    currentCancelForm = form;
    document.getElementById('cancelModal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    return false;
  }

  function closeCancelModal() {
    document.getElementById('cancelModal').classList.add('hidden');
    document.body.style.overflow = 'auto';
    currentCancelForm = null;
  }

  function confirmCancelOrder() {
    if (currentCancelForm) {
      const form = currentCancelForm;  // Save form reference before closing modal
      const submitBtn = form.querySelector('button[type="submit"]');
      
      // Disable button and show loading state
      submitBtn.disabled = true;
      submitBtn.innerHTML = `
        <svg class="animate-spin h-5 w-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
          <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
          <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
        </svg>
      `;
      
      // Close modal
      closeCancelModal();
      
      // Submit the form with saved reference
      form.submit();
    }
  }

  // Close modal on ESC key
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') {
      closeCancelModal();
    }
  });

  // Filter functionality
  function filterOrders(status) {
    const orderCards = document.querySelectorAll('.order-card');
    const tabs = document.querySelectorAll('.filter-tab');
    const searchInput = document.getElementById('orderSearch');
    
    // Clear search input when filtering
    searchInput.value = '';
    
    // Update active tab
    tabs.forEach(tab => {
      tab.classList.remove('active', 'border-yellow-500', 'text-gray-900');
      tab.classList.add('border-transparent', 'text-gray-500');
    });
    event.target.classList.add('active', 'border-yellow-500', 'text-gray-900');
    event.target.classList.remove('border-transparent', 'text-gray-500');
    
    // Filter orders
    orderCards.forEach(card => {
      const orderStatus = card.dataset.status;
      if (status === 'all') {
        card.style.display = 'block';
      } else if (status === 'pending') {
        card.style.display = (orderStatus !== 'delivered' && orderStatus !== 'cancelled') ? 'block' : 'none';
      } else {
        card.style.display = orderStatus === status ? 'block' : 'none';
      }
    });
  }

  // Search functionality
  document.getElementById('orderSearch').addEventListener('input', function(e) {
    const searchTerm = e.target.value.toLowerCase().trim();
    const orderCards = document.querySelectorAll('.order-card');
    
    // If search is empty, reset to show all orders
    if (searchTerm === '') {
      orderCards.forEach(card => {
        card.style.display = 'block';
      });
      return;
    }
    
    orderCards.forEach(card => {
      const orderId = card.dataset.orderId ? card.dataset.orderId.toLowerCase() : '';
      const searchText = card.dataset.searchText ? card.dataset.searchText.toLowerCase() : '';
      
      // Search in order ID and product names
      if (orderId.includes(searchTerm) || searchText.includes(searchTerm)) {
        card.style.display = 'block';
      } else {
        card.style.display = 'none';
      }
    });
    
    // Reset active filter tab to "All Orders" when searching
    const tabs = document.querySelectorAll('.filter-tab');
    tabs.forEach(tab => {
      tab.classList.remove('active', 'border-yellow-500', 'text-gray-900');
      tab.classList.add('border-transparent', 'text-gray-500');
    });
    tabs[0].classList.add('active', 'border-yellow-500', 'text-gray-900');
    tabs[0].classList.remove('border-transparent', 'text-gray-500');
  });

  // Calculate order counts
  document.addEventListener('DOMContentLoaded', function() {
    const orderCards = document.querySelectorAll('.order-card');
    let pendingCount = 0;
    let deliveredCount = 0;
    let cancelledCount = 0;
    
    orderCards.forEach(card => {
      const status = card.dataset.status;
      if (status === 'delivered') {
        deliveredCount++;
      } else if (status === 'cancelled') {
        cancelledCount++;
      } else {
        pendingCount++;
      }
    });
    
    document.getElementById('count-pending').textContent = pendingCount;
    document.getElementById('count-delivered').textContent = deliveredCount;
    document.getElementById('count-cancelled').textContent = cancelledCount;
  });

  // Order Again functionality
  function orderAgain(btn) {
    // Show loading state
    btn.disabled = true;
    btn.innerHTML = `
      <svg class="animate-spin h-5 w-5 mx-auto" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24">
        <circle class="opacity-25" cx="12" cy="12" r="10" stroke="currentColor" stroke-width="4"></circle>
        <path class="opacity-75" fill="currentColor" d="M4 12a8 8 0 018-8V0C5.373 0 0 5.373 0 12h4zm2 5.291A7.962 7.962 0 014 12H0c0 3.042 1.135 5.824 3 7.938l3-2.647z"></path>
      </svg>
    `;
    
    // Redirect to shop after a short delay
    setTimeout(() => {
      window.location.href = '/shop';
    }, 500);
  }

  // Rate Product functionality
  function rateProduct(orderId) {
    alert('⭐ Thank you for your interest!\n\nRating and review feature coming soon. We value your feedback!');
  }
</script>

