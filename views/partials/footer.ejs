<script>
  (function () {
    const nativeAlert = window.alert;

    window.showAppAlert = function (message) {
      if (!message) return;

      const existing = document.getElementById('app-alert-toast');
      if (existing) existing.remove();

      const alertDiv = document.createElement('div');
      alertDiv.id = 'app-alert-toast';
      alertDiv.className = 'fixed top-24 right-4 sm:right-auto sm:left-1/2 sm:-translate-x-1/2 z-50 bg-yellow-500 text-gray-900 px-3 sm:px-5 py-1.5 sm:py-2 rounded shadow-lg max-w-xs flex items-center justify-between gap-2';
      alertDiv.innerHTML = `
        <span class="text-xs sm:text-sm font-semibold flex-1">${message}</span>
        <button type="button" class="text-gray-900 hover:text-gray-700 font-bold text-lg shrink-0 ml-1" aria-label="Close alert">&times;</button>
      `;

      const closeButton = alertDiv.querySelector('button');
      closeButton.addEventListener('click', () => alertDiv.remove());

      document.body.appendChild(alertDiv);
      setTimeout(() => alertDiv.remove(), 3500);
    };

    window.alert = function (message) {
      if (!document.body) {
        nativeAlert(message);
        return;
      }
      window.showAppAlert(String(message || ''));
    };
  })();
</script>


