      <script>
        // Trending Slideshow - Multiple slides with 3 images each
        let trendingCurrentIndex = 0;
        const trendingSlides = document.querySelectorAll('.trending-slide');
        const trendingDots = document.querySelectorAll('.trending-dot');
        const trendingTrack = document.querySelector('.trending-slider-track');

        function updateTrendingSlider() {
          if (trendingSlides.length === 0) return;
          
          const offset = -trendingCurrentIndex * 100;
          trendingTrack.style.transform = `translateX(${offset}%)`;

          trendingDots.forEach((dot, index) => {
            if (index === trendingCurrentIndex) {
              dot.classList.add('active');
              dot.style.backgroundColor = '#ffffff';
            } else {
              dot.classList.remove('active');
              dot.style.backgroundColor = 'rgba(255, 255, 255, 0.6)';
            }
          });
        }

        document.getElementById('trending-prev')?.addEventListener('click', () => {
          trendingCurrentIndex = (trendingCurrentIndex - 1 + trendingSlides.length) % trendingSlides.length;
          updateTrendingSlider();
        });

        document.getElementById('trending-next')?.addEventListener('click', () => {
          trendingCurrentIndex = (trendingCurrentIndex + 1) % trendingSlides.length;
          updateTrendingSlider();
        });

        trendingDots.forEach(dot => {
          dot.addEventListener('click', () => {
            trendingCurrentIndex = parseInt(dot.getAttribute('data-index'));
            updateTrendingSlider();
          });
        });

        // Auto-slide every 6 seconds
        setInterval(() => {
          trendingCurrentIndex = (trendingCurrentIndex + 1) % trendingSlides.length;
          updateTrendingSlider();
        }, 6000);
      </script>

      <!-- Footer Link to Shop -->
      <section class="bg-white py-6 text-center rounded-lg">
        <h2 class="text-3xl font-bold mb-4">Didn't find what you're looking for?</h2>
        <a href="/shop" class="inline-block border-b-2 border-yellow-400 text-xl font-bold pb-1 hover:text-yellow-600 transition">
          View Entire Collection
        </a>
      </section>

    </div>

    <!-- Footer -->
    <%-include('./partials/footer') %>
  </div>

<% } else { %>
  <!-- Guest/Landing Page Layout (Keep original) -->
  <div class="min-h-screen grid md:grid-cols-2 font-sans">
    <div class="relative bg-gradient-to-tr from-gray-900 to-gray-800 text-white p-10 flex flex-col justify-center">
      <div class="max-w-md mx-auto">
        <h1 class="text-5xl font-extrabold mb-4 leading-tight text-yellow-400">
          Welcome to <span class="text-white">Scatch</span>
        </h1>
        <p class="text-lg font-light mb-6 text-gray-200">
          Discover premium men's & women's clothing and luxury watches curated just for you.
        </p>
        <ul class="space-y-2 text-sm text-gray-300">
          <li class="flex items-center gap-2">� Men's & Women's Fashion Collections</li>
          <li class="flex items-center gap-2">🔒 100% secure checkout</li>
          <li class="flex items-center gap-2">💬 Friendly support 24/7</li>
        </ul>
      </div>
    </div>

    <div class="flex items-center justify-center px-8 py-16">
        <div class="w-full max-w-md space-y-12">
        <!-- Forms go here -->
        <div>
          <div id="toast-container" class="py-2 text-center mb-6 rounded-full"></div>
          
          <% if (typeof registerError !== "undefined" && registerError.length > 0) { %>
            <div class="mb-4 p-3 bg-orange-50 border border-orange-200 text-orange-700 text-sm rounded-lg animate-fade-in">
              <%= registerError[0] %>
            </div>
          <% } %>

          <h2 class="text-2xl font-semibold text-gray-800 mb-6">Create your Scatch account</h2>
          <form action="/users/register" method="POST" class="space-y-4" autocomplete="off">
            <input type="text" name="fullname" placeholder="Full Name" class="w-full px-4 py-2 border rounded-md" required />
            <input type="email" name="email" placeholder="Email" class="w-full px-4 py-2 border rounded-md" required />
            <input type="password" name="password" placeholder="Password" class="w-full px-4 py-2 border rounded-md" required />
            <input type="submit" value="Sign Up" class="w-full bg-yellow-500 hover:bg-yellow-600 text-white py-3 rounded-full font-semibold cursor-pointer" />
          </form>
        </div>

        <div class="flex items-center justify-between">
          <hr class="w-full border-gray-300" />
          <span class="px-3 text-gray-400">OR</span>
          <hr class="w-full border-gray-300" />
        </div>

        <div>
          <% if (typeof loginError !== "undefined" && loginError.length > 0) { %>
            <div class="mb-4 p-3 bg-orange-50 border border-orange-200 text-orange-700 text-sm rounded-lg animate-fade-in">
              <%= loginError[0] %>
            </div>
          <% } %>

          <h2 class="text-2xl font-semibold text-gray-800 mb-6">Already have an account?</h2>
          <form action="/users/login" method="POST" class="space-y-4">
            <input type="email" name="email" placeholder="Email" class="w-full px-4 py-2 border rounded-md" required />
            <input type="password" name="password" placeholder="Password" class="w-full px-4 py-2 border rounded-md" required />
            <input type="submit" value="Login" class="w-full bg-gray-800 hover:bg-black text-white py-3 rounded-full font-semibold cursor-pointer" />
          </form>
          <p class="text-center text-gray-600 text-sm mt-4">
            Or login as <a href="/owners/login" class="text-blue-600 hover:text-blue-700 font-medium">Store Owner</a>
          </p>
        </div>
      </div>
    </div>
  </div>
<% } %>

<script>
  function createToast(message, type="success"){
    const toast=document.createElement("div");
    toast.textContent=message;
    toast.className=`px-4 py-2 rounded shadow-lg text-white ${type==="success"? "bg-green-600" : "bg-red-600"} animate-slide-in`;
    const container=document.getElementById("toast-container");
    if(container) container.appendChild(toast);
    setTimeout(()=>{
      toast.classList.add("animate-fade-out");
      setTimeout(()=> toast.remove(), 500);
    },3000);
  }

  document.addEventListener("DOMContentLoaded", () => {
     <% if (typeof success !== "undefined" && success.length > 0) { %>
        createToast("<%= success[0] %>", "success");
     <% } %>

     // Banner Slider functionality
     let currentSlide = 0;
     const sliderTrack = document.querySelector('.banner-slider-track');
     const slides = document.querySelectorAll('.banner-slide');
     const dots = document.querySelectorAll('.slider-dot');
     const totalSlides = slides.length;

     function goToSlide(index) {
       currentSlide = index;
       if (sliderTrack) {
         sliderTrack.style.transform = `translateX(-${currentSlide * 100}%)`;
       }
       
       // Update dots
       dots.forEach((dot, i) => {
         dot.classList.toggle('bg-white', i === currentSlide);
         dot.classList.toggle('bg-white/60', i !== currentSlide);
       });
     }

     function nextSlide() {
       currentSlide = (currentSlide + 1) % totalSlides;
       goToSlide(currentSlide);
     }

     function prevSlide() {
       currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
       goToSlide(currentSlide);
     }

     // Auto-play slider every 5 seconds
     let autoSlideInterval = setInterval(nextSlide, 5000);

     const resetAutoSlide = () => {
       clearInterval(autoSlideInterval);
       autoSlideInterval = setInterval(nextSlide, 5000);
     };

     // Event listeners
     document.getElementById('banner-next')?.addEventListener('click', () => {
       nextSlide();
       resetAutoSlide();
     });

     document.getElementById('banner-prev')?.addEventListener('click', () => {
       prevSlide();
       resetAutoSlide();
     });

     dots.forEach(dot => {
       dot.addEventListener('click', (e) => {
         goToSlide(parseInt(e.target.dataset.index));
         resetAutoSlide();
       });
     });

     // Initialize
     goToSlide(0);
  });
</script>
</body>
</html>
