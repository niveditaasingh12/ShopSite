<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Scatch</title>

    <!-- Remix Icons -->
    <link
      href="https://cdn.jsdelivr.net/npm/remixicon@4.2.0/fonts/remixicon.css"
      rel="stylesheet"
    />

    <link rel="stylesheet" href="/css/tailwind.css" />

    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.js"></script>

    <!-- Modern Font -->
    <link
      href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;600;700&display=swap"
      rel="stylesheet"
    />

    <style>
      body {
        font-family: "Poppins", sans-serif;
      }
    </style>
  </head>

  <body class="bg-white text-gray-800">
    <!-- Navbar with Admin Links -->
    <nav
      class="w-full px-6 lg:px-16 py-4 bg-white shadow-md sticky top-0 z-50 border-b border-gray-200"
    >
      <div class="max-w-7xl mx-auto flex items-center justify-between">
        <!-- Brand Logo -->
        <div class="text-3xl font-bold tracking-tight text-gray-900">
          <a href="/" class="hover:opacity-90 transition duration-200">
            <span class="text-yellow-500">Sca</span
            ><span class="text-gray-900">tch</span>
          </a>
        </div>

        <!-- Admin Links: primary nav items (hide link when on same page) -->
        <div class="flex items-center gap-6 text-sm font-medium">
          <div class="hidden sm:flex items-center gap-4">
            <% if (currentPath !== '/admin/dashboard') { %>
              <a href="/admin/dashboard" class="text-gray-600 hover:text-blue-600">Dashboard</a>
            <% } %>
            <% if (currentPath !== '/admin/products') { %>
              <a href="/admin/products" class="text-gray-600 hover:text-blue-600">Products</a>
            <% } %>
            <% if (currentPath !== '/admin/orders') { %>
              <a href="/admin/orders" class="text-gray-600 hover:text-blue-600">Orders</a>
            <% } %>
            <% if (currentPath !== '/admin/users') { %>
              <a href="/admin/users" class="text-gray-600 hover:text-blue-600">Users</a>
            <% } %>
          </div>

          <div class="flex items-center gap-6">
            <a
              href="/owners/logout"
              class="flex items-center gap-1 text-red-600 hover:text-red-700 transition"
            >
              <i class="ri-logout-box-r-line"></i>
              Logout
            </a>
          </div>
        </div>
      </div>
    </nav>
    <!-- subnav removed; primary admin links now in main navbar -->
    <!-- spacer to add vertical gap below navbar on all admin pages -->
    <div class="h-6 lg:h-8"></div>
  </body>
</html>
