<%- include('./partials/header') %>

<div class="min-h-screen bg-gray-50 py-8">
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8">
    
    <!-- Back Button -->
    <div class="mb-6">
      <a href="/myorders" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Orders
      </a>
    </div>

    <!-- Alert Messages -->
    <% if (success && success.length > 0) { %>
      <div class="mb-6 bg-white border-l-4 border-green-500 rounded-lg shadow-lg p-4">
        <div class="flex items-center">
          <div class="flex-shrink-0">
            <svg class="w-6 h-6 text-green-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/>
            </svg>
          </div>
          <p class="ml-3 text-sm text-gray-700"><%= success %></p>
        </div>
      </div>
    <% } %>

    <!-- Order Header Card -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6 overflow-hidden">
      <div class="bg-gradient-to-r from-yellow-400 to-yellow-500 px-6 py-4">
        <h1 class="text-2xl font-bold text-gray-900">Track Your Order</h1>
      </div>
      
      <div class="p-6">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Order ID</p>
            <p class="text-sm font-mono font-semibold text-gray-900">#<%= order._id.toString().slice(-8).toUpperCase() %></p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Order Date</p>
            <p class="text-sm font-medium text-gray-900">
              <%= new Date(order.createdAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'short', year: 'numeric' }) %>
            </p>
          </div>
          <div>
            <p class="text-xs text-gray-500 uppercase tracking-wide mb-1">Order Status</p>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-semibold
              <%= order.status === 'Delivered' ? 'bg-green-100 text-green-800' : 
                  order.status === 'Cancelled' ? 'bg-red-100 text-red-800' : 
                  'bg-yellow-100 text-yellow-800' %>">
              <%= order.status %>
            </span>
          </div>
        </div>
      </div>
    </div>

    <!-- Tracking Timeline -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-6">Order Status</h2>
      
      <% if (order.status !== 'Cancelled') { 
        const isDelivered = order.status === 'Delivered';
        const deliveryDate = new Date(order.createdAt);
        deliveryDate.setDate(deliveryDate.getDate() + 7);
      %>
        <div class="relative">
          <!-- Timeline Line -->
          <div class="absolute left-4 top-0 bottom-0 w-0.5 bg-gray-200"></div>
          <div class="absolute left-4 top-0 w-0.5 bg-yellow-500" style="height: <%= isDelivered ? '100%' : '33%' %>"></div>
          
          <!-- Order Placed -->
          <div class="relative flex items-start mb-8 pl-12">
            <div class="absolute left-0 w-8 h-8 bg-yellow-500 rounded-full flex items-center justify-center">
              <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
              </svg>
            </div>
            <div>
              <h3 class="text-base font-semibold text-gray-900">Order Placed</h3>
              <p class="text-sm text-gray-600 mt-1">
                <%= new Date(order.createdAt).toLocaleDateString('en-IN', { 
                  day: 'numeric', 
                  month: 'long', 
                  year: 'numeric',
                  hour: '2-digit',
                  minute: '2-digit'
                }) %>
              </p>
            </div>
          </div>

          <!-- Processing -->
          <div class="relative flex items-start mb-8 pl-12">
            <div class="absolute left-0 w-8 h-8 <%= isDelivered ? 'bg-yellow-500' : 'bg-yellow-500' %> rounded-full flex items-center justify-center">
              <% if (isDelivered) { %>
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              <% } else { %>
                <div class="w-3 h-3 bg-white rounded-full animate-pulse"></div>
              <% } %>
            </div>
            <div>
              <h3 class="text-base font-semibold text-gray-900">Order Processing</h3>
              <p class="text-sm text-gray-600 mt-1">Your order is being prepared for shipment</p>
            </div>
          </div>

          <!-- Shipped -->
          <div class="relative flex items-start mb-8 pl-12">
            <div class="absolute left-0 w-8 h-8 <%= isDelivered ? 'bg-yellow-500' : 'bg-gray-200' %> rounded-full flex items-center justify-center">
              <% if (isDelivered) { %>
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              <% } else { %>
                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
              <% } %>
            </div>
            <div>
              <h3 class="text-base font-semibold <%= isDelivered ? 'text-gray-900' : 'text-gray-500' %>">Shipped</h3>
              <p class="text-sm text-gray-600 mt-1">
                <%= isDelivered ? 'Your order has been shipped' : 'Estimated shipping date: ' + new Date(order.createdAt.getTime() + 2*24*60*60*1000).toLocaleDateString('en-IN', { day: 'numeric', month: 'long' }) %>
              </p>
            </div>
          </div>

          <!-- Delivered -->
          <div class="relative flex items-start pl-12">
            <div class="absolute left-0 w-8 h-8 <%= isDelivered ? 'bg-yellow-500' : 'bg-gray-200' %> rounded-full flex items-center justify-center">
              <% if (isDelivered) { %>
                <svg class="w-5 h-5 text-white" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M16.707 5.293a1 1 0 010 1.414l-8 8a1 1 0 01-1.414 0l-4-4a1 1 0 011.414-1.414L8 12.586l7.293-7.293a1 1 0 011.414 0z" clip-rule="evenodd"/>
                </svg>
              <% } else { %>
                <div class="w-3 h-3 bg-gray-400 rounded-full"></div>
              <% } %>
            </div>
            <div>
              <h3 class="text-base font-semibold <%= isDelivered ? 'text-gray-900' : 'text-gray-500' %>">Delivered</h3>
              <p class="text-sm text-gray-600 mt-1">
                <%= isDelivered ? 
                  'Order delivered on ' + new Date(order.updatedAt).toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) :
                  'Expected by ' + deliveryDate.toLocaleDateString('en-IN', { day: 'numeric', month: 'long', year: 'numeric' }) %>
              </p>
            </div>
          </div>
        </div>
      <% } else { %>
        <!-- Cancelled Status -->
        <div class="bg-red-50 border border-red-200 rounded-lg p-6 text-center">
          <div class="w-16 h-16 bg-red-100 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-red-600" fill="currentColor" viewBox="0 0 20 20">
              <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Order Cancelled</h3>
          <p class="text-sm text-gray-700">This order was cancelled. Refund will be processed within 5-7 business days.</p>
        </div>
      <% } %>
    </div>

    <!-- Order Items -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 mb-6 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Order Items</h2>
      <div class="space-y-4">
        <% order.products.forEach(item => { %>
          <div class="flex items-center gap-4 pb-4 border-b border-gray-200 last:border-0 last:pb-0">
            <img 
              src="/images/uploads/<%= item.product.image %>" 
              alt="<%= item.product.name %>"
              class="w-20 h-20 object-cover rounded-lg border border-gray-200"
            />
            <div class="flex-1">
              <h3 class="font-semibold text-gray-900"><%= item.product.name %></h3>
              <div class="flex items-center gap-4 mt-2 text-sm text-gray-600">
                <span>Qty: <%= item.quantity %></span>
                <% if (item.size) { %>
                  <span>Size: <%= item.size %></span>
                <% } %>
              </div>
            </div>
            <div class="text-right">
              <p class="text-lg font-semibold text-gray-900">₹<%= (item.product.price * item.quantity).toLocaleString('en-IN') %></p>
            </div>
          </div>
        <% }) %>
      </div>
      
      <div class="mt-6 pt-4 border-t border-gray-200">
        <div class="flex justify-between items-center">
          <span class="text-base font-semibold text-gray-900">Total Amount</span>
          <span class="text-xl font-bold text-gray-900">₹<%= order.totalAmount.toLocaleString('en-IN') %></span>
        </div>
      </div>
    </div>

    <!-- Delivery Address -->
    <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4">Delivery Address</h2>
      <div class="text-sm text-gray-700">
        <p class="font-semibold text-gray-900"><%= order.address.fullname %></p>
        <p class="mt-2"><%= order.address.address %></p>
        <p><%= order.address.city %>, <%= order.address.state %> - <%= order.address.pincode %></p>
        <% if (order.address.phone) { %>
          <p class="mt-2 flex items-center gap-2">
            <svg class="w-4 h-4 text-gray-500" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <span class="font-medium"><%= order.address.phone %></span>
          </p>
        <% } %>
      </div>
    </div>

    <!-- Help Section -->
    <div class="mt-6 text-center">
      <p class="text-sm text-gray-600 mb-3">Need help with this order?</p>
      <a href="/contact-us" class="inline-flex items-center justify-center gap-2 px-6 py-2.5 bg-yellow-500 hover:bg-yellow-600 text-gray-900 font-semibold rounded-lg">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 10h.01M12 10h.01M16 10h.01M9 16H5a2 2 0 01-2-2V6a2 2 0 012-2h14a2 2 0 012 2v8a2 2 0 01-2 2h-5l-5 5v-5z"/>
        </svg>
        Contact Support
      </a>
    </div>

  </div>
</div>

<%- include('./partials/footer') %>
