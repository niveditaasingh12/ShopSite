<%- include('./partials/header') %>

<div class="bg-gray-50 min-h-screen">
  <div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-6 sm:py-8">

    <!-- Back Button & Page Header -->
    <div class="mb-6">
      <a href="/account" class="inline-flex items-center gap-2 text-gray-600 hover:text-gray-900 font-medium text-sm mb-4">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/>
        </svg>
        Back to Account
      </a>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">Change Password</h1>
      <p class="text-gray-600">Keep your account secure by updating your password regularly</p>
    </div>

    <!-- Flash Messages -->
    <% if (error && error.length > 0) { %>
      <div class="mb-6 fixed top-24 right-4 sm:right-auto sm:left-1/2 sm:-translate-x-1/2 z-50 bg-red-500 text-white px-3 sm:px-5 py-1.5 sm:py-2 rounded shadow-lg max-w-xs flex items-center justify-between gap-2" style="animation: fadeInOut 3s ease-in-out forwards;">
        <span class="text-xs sm:text-sm font-semibold flex-1"><%= error[0] %></span>
        <button type="button" onclick="this.parentElement.remove()" class="text-white hover:text-gray-100 font-bold text-lg shrink-0 ml-1">&times;</button>
      </div>
    <% } %>

    <% if (success && success.length > 0) { %>
      <div class="mb-6 fixed top-24 right-4 sm:right-auto sm:left-1/2 sm:-translate-x-1/2 z-50 bg-yellow-500 text-gray-900 px-3 sm:px-5 py-1.5 sm:py-2 rounded shadow-lg max-w-xs flex items-center justify-between gap-2" style="animation: fadeInOut 3s ease-in-out forwards;">
        <span class="text-xs sm:text-sm font-semibold flex-1"><%= success[0] %></span>
        <button type="button" onclick="this.parentElement.remove()" class="text-gray-900 hover:text-gray-700 font-bold text-lg shrink-0 ml-1">&times;</button>
      </div>
    <% } %>

    <!-- Password Change Form -->
    <div class="bg-white rounded-lg shadow-sm">
      <div class="border-b border-gray-200 px-6 py-4">
        <h2 class="text-lg font-semibold text-gray-800">Security Settings</h2>
      </div>

      <form method="POST" action="/account/changepassword" class="p-6 space-y-6">

        <!-- Current Password -->
        <div>
          <label for="currentPassword" class="block text-sm font-medium text-gray-900 mb-2">
            Current Password <span class="text-red-500">*</span>
          </label>
          <input
            type="password"
            id="currentPassword"
            name="currentPassword"
            placeholder="Enter your current password"
            required
            class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-yellow-500 bg-white"
          />
          <p class="text-gray-500 text-xs mt-1.5">We need your current password to verify your identity</p>
        </div>

        <!-- New Password -->
        <div>
          <label for="newPassword" class="block text-sm font-medium text-gray-900 mb-2">
            New Password <span class="text-red-500">*</span>
          </label>
          <input
            type="password"
            id="newPassword"
            name="newPassword"
            placeholder="Create a strong new password"
            required
            minlength="6"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-yellow-500 bg-white"
          />
          <p class="text-gray-500 text-xs mt-1.5">Must be at least 6 characters long. Use a mix of letters, numbers, and symbols for better security</p>
        </div>

        <!-- Confirm New Password -->
        <div>
          <label for="confirmPassword" class="block text-sm font-medium text-gray-900 mb-2">
            Confirm New Password <span class="text-red-500">*</span>
          </label>
          <input
            type="password"
            id="confirmPassword"
            name="confirmPassword"
            placeholder="Re-enter your new password"
            required
            minlength="6"
            class="w-full px-4 py-3 border border-gray-300 rounded-lg text-sm focus:outline-none focus:ring-2 focus:ring-yellow-400 focus:border-yellow-500 bg-white"
          />
          <p class="text-gray-500 text-xs mt-1.5">Password confirmation must match exactly</p>
        </div>

        <!-- Security Tips Banner -->
        <div class="bg-blue-50 border border-blue-200 rounded-lg p-4">
          <p class="text-sm text-blue-900 font-medium mb-2">Password Security Tips:</p>
          <ul class="text-xs text-blue-800 space-y-1 ml-4 list-disc">
            <li>Use a combination of uppercase, lowercase, numbers, and symbols</li>
            <li>Avoid using personal information like your name or birth date</li>
            <li>Change your password every 3-6 months</li>
            <li>Never share your password with anyone</li>
          </ul>
        </div>

        <!-- Action Buttons -->
        <div class="border-t border-gray-200 pt-6 flex flex-col sm:flex-row gap-4">
          <button
            type="submit"
            class="flex-1 bg-yellow-500 hover:bg-yellow-600 text-white px-6 py-3 rounded-lg font-semibold transition"
          >
            Update Password
          </button>
          <a
            href="/account"
            class="flex-1 text-center border border-gray-300 text-gray-700 px-6 py-3 rounded-lg font-medium hover:bg-gray-50 transition"
          >
            Cancel
          </a>
        </div>

      </form>
    </div>

  </div>
</div>

<%- include('./partials/footer') %>

<style>
  @keyframes fadeInOut {
    0% {
      opacity: 1;
    }
    85% {
      opacity: 1;
    }
    100% {
      opacity: 0;
    }
  }

  .fadeInOut {
    animation: fadeInOut 3s ease-in-out forwards;
  }
</style>

<script>
  // Auto-dismiss flash message after 3 seconds
  window.addEventListener('load', () => {
    const flashMsg = document.querySelector('.fadeInOut');
    if (flashMsg) {
      setTimeout(() => {
        flashMsg.remove();
      }, 3000);
    }
  });
</script>

